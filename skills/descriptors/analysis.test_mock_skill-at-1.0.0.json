{
  "$schema": "https://spec.example.com/skill-descriptor-v3.json",
  "specVersion": "3.0",
  "id": "analysis.test_mock_skill@1.0.0",
  "displayName": "Test Mock Skill",
  "description": "A mock skill for testing",
  "idempotency": "safe",
  "sideEffects": [],
  "timeout": {
    "defaultMs": 30000,
    "maxMs": 60000
  },
  "authentication": {
    "type": "none"
  },
  "parameters": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "required_param": {
        "type": "string",
        "description": "A required parameter",
        "minLength": 1
      }
    },
    "required": [
      "required_param"
    ]
  },
  "returns": {
    "type": "object",
    "additionalProperties": false
  },
  "errors": [
    {
      "code": "INVALID_PARAMETER",
      "recoverable": false
    },
    {
      "code": "TEMPORARILY_UNAVAILABLE",
      "recoverable": true
    },
    {
      "code": "SKILL_TIMEOUT",
      "recoverable": true
    }
  ]
}